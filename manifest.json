{
  "manifest_version": 3,
  "name": "Lập's Extension",
  "version": "1.7",
  "description": "extension của Lập",
  "icons": {
    "16": "image/icon16.png",
    "32": "image/icon32.png",
    "48": "image/icon48.png",
    "128": "image/icon128.png"
  },
  "options_page": "options.html",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "alarms",
    "windows",
    "notifications",
    "system.display",
    "downloads"
  ],
  "host_permissions": [
    "*://script.google.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["selfcontrol_checker.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "config.js",
        "PasswordModule.js",
        "summaryBox.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "*://*/*"
      ],
      "js": [
        "handleBlocking.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": [
        "*://*/*"
      ],
      "exclude_matches": [
        "*://open.spotify.com/*"
      ],
      "js": [
        "media_detector.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "*://open.spotify.com/*"
      ],
      "js": [
        "spotify_detector.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://youtube.com/*"
      ],
      "js": [
        "PasswordModule.js",
        "youtube.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.google.com/search*",
        "*://google.com/search*"
      ],
      "js": [
        "google_search.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.ticketbox.vn/*",
        "*://ticketbox.vn/*"
      ],
      "js": [
        "ticketbox.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://calendar.google.com/calendar/u/0/r/eventedit?ofe=true*"
      ],
      "js": [
        "google_calendar.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.facebook.com/*",
        "*://facebook.com/*"
      ],
      "js": [
        "facebook_init.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://*.facebook.com/*",
        "*://facebook.com/*"
      ],
      "js": [
        "facebook.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "*://notebooklm.google.com/*"
      ],
      "js": [
        "notebooklm.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "python-helper/python_helper.py"
      ],
      "matches": [
        "*://*.youtube.com/*",
        "*://youtube.com/*"
      ]
    },
    {
      "resources": [
        "football-teams.json",
        "handleFootballMatch.js",
        "image/add.png"
      ],
      "matches": [
        "*://*.google.com/*",
        "*://google.com/*"
      ]
    },
    {
      "resources": [
        "image/add.png"
      ],
      "matches": [
        "*://*.ticketbox.vn/*",
        "*://ticketbox.vn/*"
      ]
    },
    {
      "resources": [
        "tuvung.html",
        "tuvung.css",
        "tuvung.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    },
    {
      "resources": [
        "music-working/index.json",
        "music-working/*.mp3"
      ],
      "matches": [
        "chrome-extension://*/*"
      ]
    }
  ],
  "commands": {
    "open_command_hub": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Mở Bảng lệnh (Lập's Hub)"
    },
    "open_option": {
      "suggested_key": {
        "default": "Ctrl+Shift+O",
        "mac": "Command+Shift+O"
      },
      "description": "Mở file option.html"
    },
    "open-extensions-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "Open chrome://extensions/"
    },
    "open_media_hub": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Mở Media Hub"
    }    
  }
}